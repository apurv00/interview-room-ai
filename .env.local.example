# Copy this file to .env.local and fill in your values

# ── Core ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Authentication ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # Generate with: openssl rand -base64 32

# ── Database ──
MONGODB_URI=mongodb://localhost:27017/interview-room-ai

# ── Redis (rate limiting + sessions) ──
REDIS_URL=redis://localhost:6379

# ── OAuth Providers (optional — leave empty to disable) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Logging ──
LOG_LEVEL=info            # debug | info | warn | error

# ── Stripe (optional — leave empty to disable payments) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
APP_URL=http://localhost:3000

# ── Cloudflare R2 Storage ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=interviewprepguru

# ── Docker Compose Auth (required for docker-compose up) ──
MONGO_USERNAME=admin
MONGO_PASSWORD=              # Generate with: openssl rand -base64 24
REDIS_PASSWORD=              # Generate with: openssl rand -base64 24

# ── Recording ──
MAX_RECORDING_SIZE_MB=50

# ── Multimodal Analysis ──
GROQ_API_KEY=gsk_...               # Groq Whisper transcription (https://console.groq.com)
DEEPGRAM_API_KEY=                   # Deepgram STT + TTS (https://console.deepgram.com)
OPENAI_API_KEY=sk-...               # OpenAI (optional, not used by multimodal pipeline)

# ── Background Jobs (Inngest) ──
# Both keys are optional in local dev — run `npm run dev:inngest` to start the
# Inngest dev server at http://localhost:8288 which handles routing without
# any signing. In production (Vercel), both keys are required. Create them in
# the Inngest Cloud dashboard: https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Feature Flags ──
FEATURE_FLAG_MULTIMODAL_ANALYSIS=true    # Enable post-interview multimodal analysis
NEXT_PUBLIC_FEATURE_MULTIMODAL=true      # Enable real-time multimodal during interview (client-side)
