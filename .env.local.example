# Copy this file to .env.local and fill in your values

# ── Core ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Authentication ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # Generate with: openssl rand -base64 32

# ── Database ──
MONGODB_URI=mongodb://localhost:27017/interview-room-ai

# ── Redis (rate limiting + sessions) ──
REDIS_URL=redis://localhost:6379

# ── OAuth Providers (optional — leave empty to disable) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Logging ──
LOG_LEVEL=info            # debug | info | warn | error

# ── Stripe (optional — leave empty to disable payments) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
APP_URL=http://localhost:3000

# ── Recording ──
RECORDING_STORAGE_PATH=/data/recordings
MAX_RECORDING_SIZE_MB=50
